# Database configuration
# Note: Set these environment variables in the Elastic Beanstalk console or via CLI
#
# DB_HOST: Your RDS MySQL endpoint
# DB_PORT: 3306 (default MySQL port)
# DB_NAME: Your database name
# DB_USER: Your database username
# DB_PASSWORD: Your database password
#
# Example setup:
# eb setenv DB_HOST=mydb.abc123.us-east-1.rds.amazonaws.com DB_USER=admin DB_PASSWORD=your-password DB_NAME=ecommerce_prod

option_settings:
  aws:elasticbeanstalk:application:environment:
    DATABASE_URL_FORMAT: "mysql://DB_USER:DB_PASSWORD@DB_HOST:DB_PORT/DB_NAME"
