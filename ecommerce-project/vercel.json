{
  "version": 2,
  "builds": [
    {
      "src": "frontend/views/**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/views/css/**/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "frontend/views/js/**/*.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "http://51.20.87.184:3000/api/$1",
      "headers": {
        "Access-Control-Allow-Origin": "*",
        "Access-Control-Allow-Methods": "GET, POST, PUT, DELETE, OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type, Authorization",
        "Access-Control-Allow-Credentials": "true"
      }
    },
    {
      "src": "/css/(.*)",
      "dest": "/frontend/views/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/frontend/views/js/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/views/$1"
    }
  ]
}